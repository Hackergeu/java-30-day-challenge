import java.util.Scanner;

public class ToDoList {

    static final int MAX_TASKS = 10;
    static String[] tasks = new String[MAX_TASKS];
    static boolean[] isDone = new boolean[MAX_TASKS];
    static int taskCount = 0;

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice;

        System.out.println("Welcome to your To-Do List!");

        do {
            System.out.println("\n----- TO-DO LIST MENU -----");
            System.out.println("1. View Tasks");
            System.out.println("2. Add Task");
            System.out.println("3. Mark Task as Complete");
            System.out.println("4. Delete Task");
            System.out.println("5. Exit");
            System.out.print("Enter your choice: ");
            choice = sc.nextInt();
            sc.nextLine(); // consume leftover newline

            switch (choice) {
                case 1 -> viewTasks();
                case 2 -> {
                    System.out.print("Enter task description: ");
                    String taskDesc = sc.nextLine();
                    addTask(taskDesc);
                }
                case 3 -> {
                    System.out.print("Enter task number to mark complete: ");
                    int completeIndex = sc.nextInt();
                    markComplete(completeIndex);
                }
                case 4 -> {
                    System.out.print("Enter task number to delete: ");
                    int deleteIndex = sc.nextInt();
                    deleteTask(deleteIndex);
                }
                case 5 -> System.out.println("Goodbye! Stay productive.");
                default -> System.out.println("Invalid choice! Please select a valid option.");
            }

        } while (choice != 5);

        sc.close();
    }

    static void addTask(String task) {
        if (taskCount >= MAX_TASKS) {
            System.out.println("Task list is full! Cannot add more tasks (max " + MAX_TASKS + ").");
            return;
        }
        tasks[taskCount] = task;
        isDone[taskCount] = false;
        taskCount++;
        System.out.println("Task added successfully!");
    }

    static void viewTasks() {
        if (taskCount == 0) {
            System.out.println("No tasks yet. Add one!");
            return;
        }

        System.out.println("\n--- Your Tasks ---");
        for (int i = 0; i < taskCount; i++) {
            String status = isDone[i] ? "[✔]" : "[ ]";
            System.out.println((i + 1) + ". " + status + " " + tasks[i]);
        }
    }

    static void markComplete(int taskNumber) {
        int index = taskNumber - 1;

        if (index < 0 || index >= taskCount) {
            System.out.println("Invalid task number!");
            return;
        }

        isDone[index] = true;
        System.out.println("Task marked as complete!");
    }

    static void deleteTask(int taskNumber) {
        int index = taskNumber - 1;

        if (index < 0 || index >= taskCount) {
            System.out.println("Invalid task number!");
            return;
        }

        // Shift all subsequent tasks one position to the left
        for (int i = index; i < taskCount - 1; i++) {
            tasks[i] = tasks[i + 1];
            isDone[i] = isDone[i + 1];
        }

        // Clear the now-duplicate last slot and shrink the count
        tasks[taskCount - 1] = null;
        isDone[taskCount - 1] = false;
        taskCount--;

        System.out.println("Task deleted successfully!");
    }
}
